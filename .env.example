# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical app URL. Production should be https://www.ihateinvoices.com
NEXT_PUBLIC_APP_URL=

# Server-only Supabase key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe server-only billing values
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Enable only after the create_invoice_atomic Supabase migration is applied and verified.
INVOICE_CREATE_RPC_ENABLED=false
